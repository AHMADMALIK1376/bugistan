{
    "env": {
        "browser": true,
        "es2021": true,
        "node": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "rules": {
        "no-cond-assign": "error",
        "no-constant-condition": "warn",
        "no-unused-vars": "warn",
        "eqeqeq": "warn",
        "no-undef": "error",
        "no-empty": "warn",
        "no-irregular-whitespace": "warn",
        "no-unreachable": "warn",
        "no-unsafe-negation": "error",
        "no-unsafe-optional-chaining": "error"
    }
}